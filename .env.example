# ITTF 数据抓取配置文件示例
# 复制此文件为 .env 并填入你的 API Key

# MiniMax API Key (用于翻译功能)
MINIMAX_API_KEY=your_api_key_here

# Web app canonical origin, used for same-origin POST validation in production
APP_ORIGIN=https://example.com

# Force session cookie Secure flag on/off if needed
SESSION_COOKIE_SECURE=true

# When running behind Cloudflare or another trusted reverse proxy,
# allow the app to read the client IP from a trusted proxy header.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IP_HEADER=cf-connecting-ip
