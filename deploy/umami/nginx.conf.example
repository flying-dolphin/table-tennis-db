# /etc/nginx/conf.d/umami.conf  （服务器 B）
#
# 用法：
#   1. 把 analytics.example.com 改成你的真实子域
#   2. 申请证书：sudo certbot --nginx -d analytics.example.com
#      certbot 会自动改写本文件加上证书路径，无需手动配 ssl_certificate
#   3. sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name analytics.example.com;

    # certbot 申请证书后会自动加 redirect 到 443
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 后台 dashboard 部分接口走 SSE/长连接
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_read_timeout                 300s;

        # 上报埋点的 POST 体很小，但 dashboard 上传 favicon 等可能稍大
        client_max_body_size               2m;
    }

    # 提高缓存命中率：tracker 脚本是静态文件，浏览器侧本地缓存即可
    location = /script.js {
        proxy_pass http://127.0.0.1:3001/script.js;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=86400";
    }
}
