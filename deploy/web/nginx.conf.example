# /etc/nginx/conf.d/ittf.conf  （服务器 A）
#
# 步骤：
#   1. 把 ittf.example.com 改成你的真实域名
#   2. sudo certbot --nginx -d ittf.example.com  自动签发 + 改写本文件
#   3. sudo nginx -t && sudo systemctl reload nginx
#
# 如果服务器 A 的 3000 端口被占用，需要在 deploy/web/.env 里改 ITTF_WEB_HOST_PORT=3001
# （或别的空闲端口），并把下面 upstream 里的端口号同步改成同一个值。
#
# ─────────────────────────────────────────────────────────────────────
# ⚠️ 限流依赖：下面的 `limit_req zone=...` 引用了两个限流区，这两个区必须
# 定义在 http {} 块里（即 /etc/nginx/nginx.conf），不能放在本 server 文件里。
# 请在 nginx.conf 的 http {} 顶部加入（只需一次）：
#
#     server_tokens off;                       # 隐藏 nginx 版本号
#     limit_req_zone  $binary_remote_addr zone=api_limit:10m  rate=20r/s;
#     limit_req_zone  $binary_remote_addr zone=auth_limit:10m rate=5r/m;
#     limit_conn_zone $binary_remote_addr zone=conn_limit:10m;
#
# 关于 $binary_remote_addr 取到的是不是「真实客户端 IP」：
#   • 若源站【直接】暴露在公网（当前就是这种）：$remote_addr 就是访客真实 IP，直接可用。
#     同时应把应用 .env 改成 TRUSTED_PROXY_IP_HEADER=x-real-ip（见报告 H4），
#     因为 cf-connecting-ip 在没有 CF 的情况下是可被客户端伪造的。
#   • 若源站【套了 Cloudflare】：$remote_addr 是 CF 节点 IP，需要用 realip 模块
#     还原真实 IP，否则所有访客会被算作同几个 CF IP 而互相挤占限流额度。
#     在 http {} 里加（CF IP 段见 https://www.cloudflare.com/ips/，需定期更新）：
#         set_real_ip_from 173.245.48.0/20;   # … 其余 CF 段全部列出
#         real_ip_header CF-Connecting-IP;
#     并务必在阿里云安全组只放行 CF 回源 IP，否则有人可直连源站伪造该头绕过限流。
# ─────────────────────────────────────────────────────────────────────

upstream ittf_web {
    server 127.0.0.1:3000;
}

server {
    listen 80;
    listen [::]:80;
    server_name ittf.example.com;

    # 头像 / 静态文件较多，开启 gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;
    gzip_min_length 1024;

    # 每个 IP 的并发连接上限，挡慢速/挂起连接（配合 http{} 里的 conn_limit 区）
    limit_conn conn_limit 20;
    # 被限流时返回 429 而不是默认 503，语义更准确
    limit_req_status 429;
    limit_conn_status 429;

    # 反代到 docker compose 中的 web 容器
    location / {
        # 正常翻页够用；批量抓取会被 burst 之外的请求拖慢（防爬 + 抗 CC）
        limit_req zone=api_limit burst=40 nodelay;

        proxy_pass http://ittf_web;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        # 只透传本机认定的真实 IP，不保留客户端伪造的 X-Forwarded-For 首段
        proxy_set_header X-Forwarded-For   $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout                 60s;
        client_max_body_size               2m;
    }

    # 认证接口：更严的限流（登录/注册/发码），抗撞库与验证码轰炸
    location /api/v1/auth/ {
        limit_req zone=auth_limit burst=5 nodelay;

        proxy_pass http://ittf_web;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout                 60s;
    }

    # Next.js 自动指纹的资源（含哈希）→ 浏览器侧长缓存
    location /_next/static/ {
        proxy_pass http://ittf_web;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # 公开静态资源：旗帜图标、字体、PWA 图标等
    location /static/ {
        proxy_pass http://ittf_web;
        proxy_set_header Host $host;
        add_header Cache-Control "public, max-age=86400";
    }
}
