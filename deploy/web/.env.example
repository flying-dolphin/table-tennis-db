# 服务器 A：ITTF Web 应用环境变量
# 复制为 deploy/web/.env，按真实值填写。这个文件不要提交到 git。
#
# 变量分类：
#   [build-arg]  公开标识符，会进客户端 bundle 或镜像 ENV，改后必须重新 build
#   [secret]     机密，通过 BuildKit --mount=type=secret 传递，不进任何镜像层
#   [runtime]    仅运行时用，由 docker compose up 时注入容器，不在镜像里
#
# ⚠️ 重要：所有注释必须独占一行，不能写在变量同一行做 inline comment
#         （docker compose 的 --env-file 解析器不剥离行内注释，会把注释当成值的一部分）

# ====== Umami 埋点（来自服务器 B，见 deploy/umami） ======
# [build-arg]
NEXT_PUBLIC_UMAMI_URL=https://analytics.your-domain.com
# [build-arg]
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ====== Microsoft Clarity ======
# [build-arg]
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ====== Sentry ======
# DSN 是公开标识符（设计上就要在浏览器里使用），可以放心进 bundle
# [build-arg]
NEXT_PUBLIC_SENTRY_DSN=
# [runtime] 服务端错误上报
SENTRY_DSN=
# [build-arg]
NEXT_PUBLIC_SENTRY_ENV=production
# [runtime]
SENTRY_ENV=production
# ORG / PROJECT 是组织/项目 slug，只是标识符
# [build-arg]
SENTRY_ORG=
# [build-arg]
SENTRY_PROJECT=
# !!! [secret] SENTRY_AUTH_TOKEN 是机密，绝不会进 build-arg、绝不会进任何镜像 layer !!!
# 它通过 BuildKit --mount=type=secret 在 build 时临时可读，build 完销毁。
# compose 在 build 时从宿主进程环境读取（即本 .env 文件被 --env-file 加载后的值）。
SENTRY_AUTH_TOKEN=

# ====== SMTP（邮箱验证码） ======
# [runtime]
SMTP_HOST=smtp.163.com
# [runtime]
SMTP_PORT=465
# [runtime]
SMTP_SECURE=true
# [runtime]
SMTP_USER=
# [runtime]
SMTP_PASS=
# [runtime]
SMTP_FROM=

# ====== Web 安全与代理信任（生产） ======
# [runtime] 对外正式域名；认证类 POST 会校验 Origin
APP_ORIGIN=https://ittf.your-domain.com
# [runtime] 生产环境建议强制 true，确保会话 Cookie 仅通过 HTTPS 发送
SESSION_COOKIE_SECURE=true
# [runtime] 仅当前面是 Cloudflare / Nginx / 其他受信任代理时启用
TRUST_PROXY_HEADERS=true
# [runtime] Cloudflare 场景用 cf-connecting-ip；如果将来换代理，这里也要同步调整
TRUSTED_PROXY_IP_HEADER=cf-connecting-ip

# ====== 宿主机端口（仅在 3000 被占用时改） ======
# [runtime] 容器内 Next.js 始终监听 3000，这里只控制宿主侧映射端口。
# 改了之后 nginx.conf 里 proxy_pass 的端口号也要同步改。
ITTF_WEB_HOST_PORT=3000

# ====== 数据卷路径 ======
# 宿主上 SQLite 数据库、抓取产物以及头像图片的根目录，会挂载到容器 /app/data。
# 必须存在的子目录：
#   $ITTF_DATA_DIR/db/                       SQLite 主库（首次启动会自动迁移）
#   $ITTF_DATA_DIR/web_assets/avatars/       前端 /images/avatars/* 的实际文件
#   $ITTF_DATA_DIR/web_assets/crops/         前端 /images/crops/* 的实际文件
# 首次部署时把仓库里的 web/public/images/{avatars,crops} 拷到 web_assets/ 下：
#   mkdir -p $ITTF_DATA_DIR/web_assets
#   cp -r web/public/images/avatars $ITTF_DATA_DIR/web_assets/avatars
#   cp -r web/public/images/crops   $ITTF_DATA_DIR/web_assets/crops
# [runtime]
ITTF_DATA_DIR=/opt/ittf/data

# ====== 阿里云 ACR 镜像（生产）======
# 设置后 compose 会从 ACR 拉镜像；留空则按 deploy/web/Dockerfile 本地 build
# 生产推荐用 commit short sha 或语义化版本作 tag，便于回滚
# [runtime]
ITTF_WEB_IMAGE=crpi-0nufvytst96nosej.cn-beijing.personal.cr.aliyuncs.com/doubao_tt/doubao_web:latest
